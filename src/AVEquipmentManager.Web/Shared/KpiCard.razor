<MudPaper Class="pa-4" Elevation="2" Style="@($"border-left: 4px solid {AccentColor}; height:100%;")">
    <MudStack Row AlignItems="AlignItems.Center" Spacing="2" Class="mb-2">
        <MudIcon Icon="@Icon" Style="@($"color:{AccentColor};")" Size="Size.Medium" />
        <MudText Typo="Typo.body2" Color="MudBlazor.Color.Secondary" Style="font-weight:500;">@Title</MudText>
    </MudStack>
    <MudStack Row AlignItems="AlignItems.Baseline" Spacing="1">
        <MudText Typo="Typo.h4" Style="@($"color:{AccentColor}; font-weight:700;")">@Value</MudText>
        @if (!string.IsNullOrEmpty(Unit))
        {
            <MudText Typo="Typo.caption" Color="MudBlazor.Color.Secondary">@Unit</MudText>
        }
    </MudStack>
    <MudText Typo="Typo.caption" Color="MudBlazor.Color.Secondary" Class="mt-2" Style="display:block;">
        @Description
    </MudText>
</MudPaper>

@code {
    [Parameter] public string Title { get; set; } = "";
    [Parameter] public string Value { get; set; } = "—";
    [Parameter] public string Unit { get; set; } = "";
    [Parameter] public string Description { get; set; } = "";

    /// <summary>
    /// CSS color string for the card's left border, icon, and headline value.
    /// Named AccentColor (not Color) to avoid shadowing MudBlazor's Color enum.
    /// </summary>
    [Parameter] public string AccentColor { get; set; } = "#2E7D32";

    [Parameter] public string Icon { get; set; } = "";
}
