@inject IJSRuntime JS
@inject NavigationManager Nav

<style>
    @@media print {
        .no-print, .mud-appbar, .mud-drawer, .mud-drawer-overlay,
        .mud-popover-provider, .mud-snackbar-provider { display: none !important; }
        .mud-main-content { padding: 0 !important; margin-top: 0 !important; }
        .report-page { box-shadow: none !important; border: none !important; }
        a { color: inherit; text-decoration: none; }
        body { background: white !important; }
    }
    .report-page { background: white; padding: 24px; }
    .report-brand { color: #2E7D32; font-weight: 700; letter-spacing: 0.04em; }
</style>

<div class="no-print" style="margin-bottom:16px;">
    <MudButton Variant="Variant.Outlined" Color="Color.Default"
               StartIcon="@Icons.Material.Filled.ArrowBack"
               OnClick="@(() => Nav.NavigateTo("/reports"))" Class="mr-2">
        Back to Reports
    </MudButton>
    <MudButton Variant="Variant.Filled" Color="Color.Primary"
               StartIcon="@Icons.Material.Filled.Print"
               OnClick="PrintAsync">
        Print / Save as PDF
    </MudButton>
</div>

<MudPaper Class="report-page" Elevation="2">
    <!-- Header -->
    <div style="border-bottom: 3px solid #2E7D32; padding-bottom: 12px; margin-bottom: 20px;">
        <div style="display:flex; justify-content:space-between; align-items:flex-end;">
            <div>
                <div class="report-brand" style="font-size:1.1rem;">AVAMS</div>
                <div style="font-size:0.85rem; color:#555;">Audio-Visual Asset Management System</div>
            </div>
            <div style="text-align:right; font-size:0.85rem; color:#555;">
                Generated: @DateTime.Now.ToString("MMMM d, yyyy · HH:mm")
            </div>
        </div>
        <MudText Typo="Typo.h5" Class="mt-3" Style="color:#1B5E20; font-weight:600;">@Title</MudText>
        @if (!string.IsNullOrEmpty(Subtitle))
        {
            <MudText Typo="Typo.body2" Color="Color.Secondary">@Subtitle</MudText>
        }
    </div>

    @ChildContent

    <!-- Footer -->
    <div style="margin-top:32px; padding-top:12px; border-top:1px solid #ccc; font-size:0.75rem; color:#777; text-align:center;">
        AVAMS — Web-based Audio-Visual Asset Management System · Generated by the Reporting module
    </div>
</MudPaper>

@code {
    [Parameter] public string Title { get; set; } = "Report";
    [Parameter] public string? Subtitle { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }

    private async Task PrintAsync()
    {
        await JS.InvokeVoidAsync("window.print");
    }
}
