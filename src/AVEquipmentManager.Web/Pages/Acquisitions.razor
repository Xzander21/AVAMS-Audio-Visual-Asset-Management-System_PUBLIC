@page "/acquisitions"
@attribute [Authorize(Roles = "Admin,Supervisor,AVStaff,Staff")]
@inject AcquisitionService AcquisitionSvc
@inject IDialogService DialogSvc
@inject ISnackbar Snackbar

<PageTitle>Acquisitions - AVAMS</PageTitle>

<MudText Typo="Typo.h4" Class="mb-2">
    <MudIcon Icon="@Icons.Material.Filled.ShoppingCart" Class="mr-2" /> Acquisition Transactions
</MudText>
<MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
    The Plan &#x2192; Acquire &#x2192; Deploy phase of the ITIL asset lifecycle. Each acquisition moves through
    Planned &#x2192; Ordered &#x2192; Received &#x2192; Deployed, or can be Cancelled at any time before Deployed.
    Deploying an acquisition creates the linked Equipment record automatically.
</MudText>

@if (_loading)
{
    <MudProgressCircular Indeterminate="true" />
}
else
{
    <MudGrid Class="mb-4">
        <MudItem xs="6" md="2"><MudPaper Class="pa-3" Elevation="2">
            <MudText Typo="Typo.caption">Planned</MudText>
            <MudText Typo="Typo.h5" Style="color:#0288D1;">@(_summary?.Planned ?? 0)</MudText>
        </MudPaper></MudItem>
        <MudItem xs="6" md="2"><MudPaper Class="pa-3" Elevation="2">
            <MudText Typo="Typo.caption">Ordered</MudText>
            <MudText Typo="Typo.h5" Style="color:#F9A825;">@(_summary?.Ordered ?? 0)</MudText>
        </MudPaper></MudItem>
        <MudItem xs="6" md="2"><MudPaper Class="pa-3" Elevation="2">
            <MudText Typo="Typo.caption">Received</MudText>
            <MudText Typo="Typo.h5" Style="color:#7B1FA2;">@(_summary?.Received ?? 0)</MudText>
        </MudPaper></MudItem>
        <MudItem xs="6" md="2"><MudPaper Class="pa-3" Elevation="2">
            <MudText Typo="Typo.caption">Deployed</MudText>
            <MudText Typo="Typo.h5" Style="color:#2E7D32;">@(_summary?.Deployed ?? 0)</MudText>
        </MudPaper></MudItem>
        <MudItem xs="6" md="2"><MudPaper Class="pa-3" Elevation="2">
            <MudText Typo="Typo.caption">Cancelled</MudText>
            <MudText Typo="Typo.h5">@(_summary?.Cancelled ?? 0)</MudText>
        </MudPaper></MudItem>
        <MudItem xs="6" md="2"><MudPaper Class="pa-3" Elevation="2" Style="background:#E8F5E9;">
            <MudText Typo="Typo.caption">Total</MudText>
            <MudText Typo="Typo.h5" Style="color:#1B5E20;">@(_summary?.Total ?? 0)</MudText>
        </MudPaper></MudItem>
    </MudGrid>

    <MudPaper Class="pa-4 mb-4" Elevation="1">
        <MudGrid Spacing="2">
            <MudItem xs="12" md="6">
                <MudTextField @bind-Value="_search" Label="Search by item or vendor"
                              Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                              Clearable="true" Immediate="true" />
            </MudItem>
            <MudItem xs="12" md="4">
                <MudSelect T="string" Label="Status" @bind-Value="_filterStatus" Clearable="true">
                    <MudSelectItem Value="@("")">All</MudSelectItem>
                    @foreach (AcquisitionStatus s in Enum.GetValues(typeof(AcquisitionStatus)))
                    {
                        <MudSelectItem T="string" Value="@s.ToString()">@s</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" md="2" Class="d-flex align-end">
                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Add"
                           OnClick="OpenAddDialog" FullWidth="true" Style="height:56px;">
                    + PLAN
                </MudButton>
            </MudItem>
        </MudGrid>
    </MudPaper>

    <MudTable Items="@Filtered" Dense="true" Hover="true" Striped="true" Breakpoint="Breakpoint.Sm">
        <HeaderContent>
            <MudTh>#</MudTh>
            <MudTh>Item</MudTh>
            <MudTh>Category</MudTh>
            <MudTh>Vendor</MudTh>
            <MudTh>Qty</MudTh>
            <MudTh>Unit Cost</MudTh>
            <MudTh>Intended Room</MudTh>
            <MudTh>Status</MudTh>
            <MudTh>Actions</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="#">#@context.Id</MudTd>
            <MudTd DataLabel="Item">@context.ItemName</MudTd>
            <MudTd DataLabel="Category">
                <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">@context.Category</MudChip>
            </MudTd>
            <MudTd DataLabel="Vendor">@(context.Vendor ?? "—")</MudTd>
            <MudTd DataLabel="Qty">@context.Quantity</MudTd>
            <MudTd DataLabel="Unit Cost">@(context.UnitCost?.ToString("N2") ?? "—")</MudTd>
            <MudTd DataLabel="Intended Room">@(context.IntendedRoom ?? "—")</MudTd>
            <MudTd DataLabel="Status">
                <MudChip T="string" Size="Size.Small" Color="@StatusColor(context.Status)">@context.Status</MudChip>
            </MudTd>
            <MudTd DataLabel="Actions">
                @if (context.Status == AcquisitionStatus.Planned)
                {
                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Color="Color.Primary"
                                   OnClick="@(() => OpenEditDialog(context))" Title="Edit" />
                    <MudIconButton Icon="@Icons.Material.Filled.ShoppingCart" Size="Size.Small" Color="Color.Warning"
                                   OnClick="@(() => OrderAsync(context))" Title="Mark Ordered" />
                }
                @if (context.Status == AcquisitionStatus.Ordered)
                {
                    <MudIconButton Icon="@Icons.Material.Filled.LocalShipping" Size="Size.Small" Color="Color.Secondary"
                                   OnClick="@(() => ReceiveAsync(context))" Title="Mark Received" />
                }
                @if (context.Status == AcquisitionStatus.Received)
                {
                    @* Deploy — "Adding of Equipment" — SUPERVISOR ONLY per client directive (2026-06-15) *@
                    <AuthorizeView Roles="Supervisor" Context="deployCtx">
                        <Authorized>
                            <MudIconButton Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Small" Color="Color.Success"
                                           OnClick="@(() => OpenDeployDialog(context))" Title="Deploy (create Equipment)" />
                        </Authorized>
                    </AuthorizeView>
                }
                @if (context.Status != AcquisitionStatus.Deployed && context.Status != AcquisitionStatus.Cancelled)
                {
                    <MudIconButton Icon="@Icons.Material.Filled.Cancel" Size="Size.Small" Color="Color.Default"
                                   OnClick="@(() => CancelAsync(context))" Title="Cancel" />
                }
                @if (context.Status == AcquisitionStatus.Cancelled)
                {
                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                                   OnClick="@(() => DeleteAsync(context))" Title="Delete (Cancelled only)" />
                }
            </MudTd>
        </RowTemplate>
        <NoRecordsContent>
            <MudText Color="Color.Secondary" Class="pa-4">No acquisitions match your filters.</MudText>
        </NoRecordsContent>
        <PagerContent><MudTablePager /></PagerContent>
    </MudTable>
}

@code {
    private List<AcquisitionDto> _all = new();
    private AcquisitionSummaryClientDto? _summary;
    private bool _loading = true;
    private string _search = "";
    private string _filterStatus = "";

    private IEnumerable<AcquisitionDto> Filtered => _all.Where(a =>
        (string.IsNullOrWhiteSpace(_search) ||
         a.ItemName.Contains(_search, StringComparison.OrdinalIgnoreCase) ||
         (a.Vendor ?? "").Contains(_search, StringComparison.OrdinalIgnoreCase)) &&
        (string.IsNullOrWhiteSpace(_filterStatus) || a.Status.ToString() == _filterStatus));

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        try
        {
            _all = await AcquisitionSvc.GetAllAsync();
            _summary = await AcquisitionSvc.GetSummaryAsync();
        }
        catch (Exception ex) { Snackbar.Add($"Error: {ex.Message}", Severity.Error); }
        _loading = false;
    }

    private async Task OpenAddDialog()
    {
        var p = new DialogParameters { ["Acquisition"] = null };
        var opts = new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true };
        var d = await DialogSvc.ShowAsync<AcquisitionDialog>("Plan New Acquisition", p, opts);
        if (!(await d.Result)!.Canceled) await LoadAsync();
    }

    private async Task OpenEditDialog(AcquisitionDto a)
    {
        var p = new DialogParameters { ["Acquisition"] = a };
        var opts = new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true };
        var d = await DialogSvc.ShowAsync<AcquisitionDialog>("Edit Acquisition", p, opts);
        if (!(await d.Result)!.Canceled) await LoadAsync();
    }

    private async Task OpenDeployDialog(AcquisitionDto a)
    {
        var p = new DialogParameters { ["Acquisition"] = a };
        var opts = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true };
        var d = await DialogSvc.ShowAsync<DeployAcquisitionDialog>("Deploy Equipment", p, opts);
        if (!(await d.Result)!.Canceled) await LoadAsync();
    }

    private async Task OrderAsync(AcquisitionDto a)
    {
        bool? ok = await DialogSvc.ShowMessageBox("Mark Ordered?",
            $"Confirm that PO for '{a.ItemName}' has been issued.", yesText: "Confirm", cancelText: "Cancel");
        if (ok != true) return;
        var (data, err) = await AcquisitionSvc.OrderAsync(a.Id);
        if (data != null) { Snackbar.Add("Marked Ordered.", Severity.Success); await LoadAsync(); }
        else Snackbar.Add($"Error: {err}", Severity.Error);
    }

    private async Task ReceiveAsync(AcquisitionDto a)
    {
        bool? ok = await DialogSvc.ShowMessageBox("Mark Received?",
            $"Confirm that '{a.ItemName}' has been physically received.", yesText: "Confirm", cancelText: "Cancel");
        if (ok != true) return;
        var (data, err) = await AcquisitionSvc.ReceiveAsync(a.Id);
        if (data != null) { Snackbar.Add("Marked Received.", Severity.Success); await LoadAsync(); }
        else Snackbar.Add($"Error: {err}", Severity.Error);
    }

    private async Task CancelAsync(AcquisitionDto a)
    {
        bool? ok = await DialogSvc.ShowMessageBox("Cancel acquisition?",
            $"Cancel the acquisition of '{a.ItemName}'?", yesText: "Cancel acquisition", cancelText: "Keep");
        if (ok != true) return;
        var (data, err) = await AcquisitionSvc.CancelAsync(a.Id);
        if (data != null) { Snackbar.Add("Cancelled.", Severity.Success); await LoadAsync(); }
        else Snackbar.Add($"Error: {err}", Severity.Error);
    }

    private async Task DeleteAsync(AcquisitionDto a)
    {
        bool? ok = await DialogSvc.ShowMessageBox("Delete cancelled acquisition?",
            $"Permanently remove acquisition #{a.Id}?", yesText: "Delete", cancelText: "Cancel");
        if (ok != true) return;
        var (success, err) = await AcquisitionSvc.DeleteAsync(a.Id);
        if (success) { Snackbar.Add("Deleted.", Severity.Success); await LoadAsync(); }
        else Snackbar.Add($"Error: {err}", Severity.Error);
    }

    private static Color StatusColor(AcquisitionStatus s) => s switch
    {
        AcquisitionStatus.Planned   => Color.Info,
        AcquisitionStatus.Ordered   => Color.Warning,
        AcquisitionStatus.Received  => Color.Secondary,
        AcquisitionStatus.Deployed  => Color.Success,
        AcquisitionStatus.Cancelled => Color.Default,
        _                            => Color.Default
    };
}
